AICODING_DB_URL=sqlite:///./runtime/aicoding_mvp.db
AICODING_VECTOR_BACKEND=simple
AICODING_DB_POOL_SIZE=5
AICODING_DB_MAX_OVERFLOW=10
AICODING_ENV=dev
AICODING_API_KEY=
AICODING_API_BASE_URL=http://127.0.0.1:8000
AICODING_API_TIMEOUT_SEC=30
AICODING_CLIENT_TYPE=cli
AICODING_TENANT_ID=
AICODING_TEAM_ID=
AICODING_USER_ID=
AICODING_LLM_BASE_URL=
AICODING_LLM_API_KEY=
AICODING_LLM_MODEL=
AICODING_LLM_CHAT_PATH=/v1/chat/completions
AICODING_LLM_TIMEOUT_SEC=30

# PostgreSQL example
# AICODING_DB_URL=postgresql+psycopg://postgres:postgres@localhost:5432/aicoding_mvp
# AICODING_VECTOR_BACKEND=pgvector
# AICODING_API_KEY=replace-with-real-secret
# AICODING_API_BASE_URL=http://127.0.0.1:8000
# Recommended DeepSeek example
# AICODING_LLM_BASE_URL=https://api.deepseek.com
# AICODING_LLM_API_KEY=replace-with-real-secret
# AICODING_LLM_MODEL=deepseek-chat
